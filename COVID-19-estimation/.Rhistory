# =============================================================================
# 6. Convergence diagnostics
# =============================================================================
hpdi <- function(x, p = 0.95) {
x <- sort(x); n <- length(x)
g <- max(1L, floor(p * n))
w <- x[(g + 1L):n] - x[1L:(n - g)]
lo <- which.min(w)
c(lo = x[lo], hi = x[lo + g])
}
